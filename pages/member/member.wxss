/* member.wxss */

/* 全局样式重置 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

/* 头部会员信息区域 */
.header-section {
  background-image: url('/images/header-bg.png');
  background-size: cover;
  background-position: center;
  padding: 40rpx 30rpx;
  color: #333;
}

.user-info-container {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar-container {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #fff;
  padding: 4rpx;
  margin-right: 20rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-level {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.complete-profile-btn {
  font-size: 26rpx;
  color: #FF6B6B;
}

/* 积分、优惠券、勋章统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  padding: 20rpx 0;
  border-radius: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #333;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
}

/* 等级进度条 */
.level-progress {
  background-color: rgba(255, 255, 255, 0.8);
  padding: 20rpx;
  border-radius: 12rpx;
}

.progress-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.progress-bar-container {
  width: 100%;
  height: 12rpx;
  background-color: #e6e6e6;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 100%;
  background-color: #FF6B6B;
  border-radius: 6rpx;
}

.progress-number {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

/* 会员权益区域 */
.benefits-section {
  background-color: #fff;
  margin: 20rpx 20rpx 0;
  padding: 30rpx;
  border-radius: 16rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.view-benefits-btn {
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.view-benefits-btn text {
  font-size: 28rpx;
  color: #FF6B6B;
}

/* 功能菜单区域 */
.menu-section {
  background-color: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
}

.menu-grid {
  display: flex;
  flex-wrap: wrap;
}

.menu-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 12rpx;
}

.menu-icon image {
  width: 48rpx;
  height: 48rpx;
}

.menu-text {
  font-size: 26rpx;
  color: #333;
}

/* 底部版权信息 */
.footer-section {
  margin-top: 40rpx;
  padding: 20rpx;
  text-align: center;
}

.copyright {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.powered-by {
  display: block;
  font-size: 22rpx;
  color: #ccc;
}