/* index.wxss */
.scrollarea {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.container {
  padding: 0rpx 10rpx !important;
  padding-bottom: 120rpx !important; /* 为底部标签栏留出空间 */
  background-color: #f5f5f5;
  min-height: calc(100vh - 100rpx); /* 减去底部标签栏高度 */
  align-items: stretch !important;
  display: block !important;
  height: auto !important;
}

.section {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 0rpx 16rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #1890ff;
  padding-left: 16rpx;
}

.student-list {
  margin-top: 16rpx;
}

.student-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e8e8e8;
  width: 100vw !important;
  max-width: calc(100vw - 20rpx);
  box-sizing: border-box;
  margin-left: -10rpx;
}

.student-info {
  flex: 1;
}

.student-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.student-points {
  display: block;
  font-size: 24rpx;
  color: #1890ff;
  font-weight: bold;
}

.student-actions {
  display: flex;
}

.btn-small {
  padding: 12rpx 20rpx !important;
  font-size: 22rpx !important;
  line-height: 1 !important;
  border-radius: 8rpx !important;
}

.btn-small:first-child {
  background-color: #52c41a !important;
  color: white !important;
  border: none !important;
}

.btn-small:last-child {
  background-color: #ff4d4f !important;
  color: white !important;
  border: none !important;
}

.search-sort-area {
  display: flex;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.sort-btn {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  background-color: #1890ff;
  color: white;
  border: none;
  border-radius: 8rpx;
}


.add-student-form {
  display: flex;
  align-items: center;
}

.input {
  flex: 1;
  padding: 20rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  background: white;
}

.btn-primary {
  background-color: #1890ff !important;
  color: white !important;
  border: none !important;
  border-radius: 8rpx !important;
  padding: 20rpx 32rpx !important;
  font-size: 28rpx !important;
}

.btn-secondary {
  background-color: #f5f5f5 !important;
  color: #666 !important;
  border: 1rpx solid #d9d9d9 !important;
  border-radius: 8rpx !important;
  padding: 20rpx 32rpx !important;
  font-size: 28rpx !important;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 16rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80%;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.points-summary {
  text-align: center;
  margin-bottom: 24rpx;
}

.total-points {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}

.points-history {
  margin-top: 24rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.history-time {
  font-size: 22rpx;
  color: #999;
  width: 180rpx;
}

.history-desc {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  margin: 0 20rpx;
}

.history-points {
  font-size: 26rpx;
  font-weight: bold;
  width: 100rpx;
  text-align: right;
}

.history-points.positive {
  color: #52c41a;
}

.history-points.negative {
  color: #ff4d4f;
}

.modal-actions {
  display: flex;
  margin-top: 32rpx;
}

.modal-actions button {
  flex: 1;
}
