/* pages/profile/profile.wxss */
.container {
  padding: 0 !important;
  background-color: #f5f5f5;
  min-height: 100vh;
  height: auto !important;
  display: block !important;
  align-items: stretch !important;
  justify-content: flex-start !important;
}

/* 用户信息区域 */
.user-info-section {
  display: flex;
  align-items: center;
  padding: 40rpx 10rpx;
  background: linear-gradient(135deg, #1890ff 0%, #722ed1 100%);
  color: white;
  width: 100%;
  box-sizing: border-box;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  margin-right: 32rpx;
}

.avatar image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: white;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: block;
}

.user-role {
  font-size: 28rpx;
  opacity: 0.8;
}

/* 统计信息区域 */
.stats-section {
  display: flex;
  background: white;
  padding: 32rpx 10rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 功能菜单区域 */
.menu-section {
  background: white;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.menu-title {
  padding: 24rpx 10rpx;
  font-size: 24rpx;
  color: #999;
  background: #fafafa;
  width: 100%;
  box-sizing: border-box;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
}

.menu-icon image {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.menu-arrow image {
  width: 20rpx;
  height: 20rpx;
  color: #999;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #999;
}